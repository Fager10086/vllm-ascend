import weakref

import torch
from vllm.triton_utils import tl, triton

from vllm_ascend.ops.triton.fla.utils import prepare_chunk_offsets, safe_exp
from vllm_ascend.ops.triton.triton_utils import get_aicore_num, init_device_properties_triton

# Cache for transposed g tensor: key=id(g), value=(weakref_to_g, transposed_g)
# Avoids repeated g.transpose+contiguous when the same tensor is reused
_g_transposed_cache: dict = {}

# Cache for chunk_offsets: key=(id(cu_seqlens), BT), value=(weakref, chunk_offsets)
_chunk_offsets_cache: dict = {}


def _get_g_transposed(g: torch.Tensor) -> torch.Tensor:
    g_id = id(g)
    if g_id in _g_transposed_cache:
        ref, cached = _g_transposed_cache[g_id]
        if ref() is g:
            return cached
    result = g.transpose(1, 2).contiguous()
    _g_transposed_cache[g_id] = (weakref.ref(g), result)
    return result


def _get_chunk_offsets(cu_seqlens: torch.Tensor, BT: int) -> torch.Tensor:
    key = (id(cu_seqlens), BT)
    if key in _chunk_offsets_cache:
        ref, cached = _chunk_offsets_cache[key]
        if ref() is cu_seqlens:
            return cached
    result = prepare_chunk_offsets(cu_seqlens, BT)
    _chunk_offsets_cache[key] = (weakref.ref(cu_seqlens), result)
    return result


@triton.heuristics(
    {
        "USE_G": lambda args: args["g"] is not None,
        "IS_VARLEN": lambda args: args["cu_seqlens"] is not None,
    }
)
@triton.jit(do_not_specialize=["T", "NT_SPLIT"])
def chunk_fwd_kernel_o(
    q,
    k,
    v,
    h,
    g,
    o,
    cu_seqlens,
    chunk_offsets,
    scale,
    T,
    H,
    Hg,
    K,
    V,
    NT_SPLIT,
    BT: tl.constexpr,
    BK: tl.constexpr,
    BV: tl.constexpr,
    USE_G: tl.constexpr,
    IS_VARLEN: tl.constexpr,
):
    i_v, i_nh, i_ts = tl.program_id(0), tl.program_id(1), tl.program_id(2)
    i_n, i_h = i_nh // H, i_nh % H
    T_max = T

    if IS_VARLEN:
        bos, eos = tl.load(cu_seqlens + i_n).to(tl.int32), tl.load(cu_seqlens + i_n + 1).to(tl.int32)
        T = eos - bos
        NT = tl.cdiv(T, BT)
        boh = tl.load(chunk_offsets + i_n).to(tl.int64)
    else:
        bos, eos = i_n * T, i_n * T + T
        NT = tl.cdiv(T, BT)
        boh = i_n * NT

    chunks_per_split = tl.cdiv(NT, NT_SPLIT)
    t_start = i_ts * chunks_per_split
    t_end = tl.minimum(t_start + chunks_per_split, NT)

    if t_start >= NT:
        return

    q += (bos * Hg + i_h // (H // Hg)) * K
    k += (bos * Hg + i_h // (H // Hg)) * K
    v += (bos * H + i_h) * V
    o += (bos * H + i_h) * V

    h_base_start = h + (boh * H + i_h).to(tl.int64) * K * V
    h_stride = (H * K * V).to(tl.int64)

    o_i = tl.arange(0, BT).to(tl.float32)
    m_A = o_i[:, None] >= o_i[None, :]

    if USE_G:
        g_ptr_base = g + bos + i_h * T_max

    for i_t in range(t_start, t_end):
        h_base = h_base_start + i_t * h_stride
        b_o = tl.zeros([BT, BV], dtype=tl.float32)
        b_A = tl.zeros([BT, BT], dtype=tl.float32)

        for i_k in range(tl.cdiv(K, BK)):
            p_q = tl.make_block_ptr(q, (T, K), (Hg * K, 1), (i_t * BT, i_k * BK), (BT, BK), (1, 0))
            p_k = tl.make_block_ptr(k, (K, T), (1, Hg * K), (i_k * BK, i_t * BT), (BK, BT), (0, 1))
            p_h = tl.make_block_ptr(h_base, (K, V), (V, 1), (i_k * BK, i_v * BV), (BK, BV), (1, 0))
            # [BT, BK]
            b_q = tl.load(p_q, boundary_check=(0, 1))
            # [BK, BT]
            b_k = tl.load(p_k, boundary_check=(0, 1))
            # [BK, BV]
            b_h = tl.load(p_h, boundary_check=(0, 1))

            # [BT, BK] @ [BK, BV] -> [BT, BV]
            b_o += tl.dot(b_q, b_h)
            # [BT, BK] @ [BK, BT] -> [BT, BT]
            b_A += tl.dot(b_q, b_k)

        if USE_G:
            offs_t = i_t * BT + tl.arange(0, BT)
            mask_t = offs_t < T
            b_g_raw = tl.load(g_ptr_base + offs_t, mask=mask_t)
            b_g = tl.where(mask_t, b_g_raw, 0.0)

            b_o = b_o * tl.exp(b_g)[:, None]
            b_A = b_A * safe_exp(b_g[:, None] - b_g[None, :])

        b_A = tl.where(m_A, b_A, 0)

        p_v = tl.make_block_ptr(v, (T, V), (H * V, 1), (i_t * BT, i_v * BV), (BT, BV), (1, 0))
        p_o = tl.make_block_ptr(o, (T, V), (H * V, 1), (i_t * BT, i_v * BV), (BT, BV), (1, 0))

        b_v = tl.load(p_v, boundary_check=(0, 1))
        # to fix mma -> mma layout conversion
        # already solved by fla v3.2 or higher
        b_o = b_o * scale + tl.dot(b_A.to(b_v.dtype), b_v) * scale
        tl.store(p_o, b_o.to(p_o.dtype.element_ty), boundary_check=(0, 1))


def chunk_fwd_o(
    q: torch.Tensor,
    k: torch.Tensor,
    v: torch.Tensor,
    h: torch.Tensor,
    g: torch.Tensor | None = None,
    scale: float | None = None,
    cu_seqlens: torch.LongTensor | None = None,
    chunk_size: int = 64,
) -> torch.Tensor:
    B, T, Hg, K, V = *q.shape, v.shape[-1]
    H = v.shape[-2]
    BT = chunk_size

    if scale is None:
        scale = k.shape[-1] ** -0.5

    o = torch.empty_like(v)

    if cu_seqlens is None:
        N, chunk_offsets = B, None
        NT_max = triton.cdiv(T, BT)
    else:
        N = len(cu_seqlens) - 1
        chunk_offsets = _get_chunk_offsets(cu_seqlens, BT)
        NT_max = triton.cdiv(T, BT)

    init_device_properties_triton()
    num_aicores = get_aicore_num()
    outer_progs = triton.cdiv(V, 128) * N * H
    NT_split = max(1, (num_aicores + outer_progs - 1) // outer_progs)
    NT_split = min(NT_split, NT_max)

    def grid(meta):
        return (triton.cdiv(V, meta["BV"]), N * H, NT_split)
        return get_nunveccore() // 2

    g_t = _get_g_transposed(g)
    chunk_fwd_kernel_o[grid](
        q=q,
        k=k,
        v=v,
        h=h,
        g=g_t,
        o=o,
        cu_seqlens=cu_seqlens,
        chunk_offsets=chunk_offsets,
        scale=scale,
        T=T,
        H=H,
        Hg=Hg,
        K=K,
        V=V,
        NT_SPLIT=NT_split,
        BT=BT,
        BK=128,
        BV=128,
        num_warps=4,
        num_stages=2,
    )
    return o

if __name__ == "__main__":
    torch.manual_seed(42)
    device = "npu"
    dtype = torch.float16  

    T = 10012
    H = 2
    D = 128
    dtype = torch.bfloat16
    from vllm_ascend.ops.triton.triton_utils import init_device_properties_triton
    import time
    init_device_properties_triton()
    
    q = torch.randn((1, T, H, D), device=device, dtype=dtype)
    k = torch.randn(1, T, H, D, device=device, dtype=dtype)
    v = torch.randn((1, T, 8, D), device=device, dtype=dtype)
    B, T, Hg, K, V = *k.shape, v.shape[-1]
    chunk_size = 64
    BT = chunk_size
    NT = triton.cdiv(T, BT)
    h = k.new_empty(B, NT, 8, K, V)
    g = torch.randn((1, T, 8), device=device, dtype=torch.float32)
    scale = k.shape[-1] ** -0.5
    cu_seqlens:list[int] = [0, T]
    cu_seqlens = torch.LongTensor(cu_seqlens).to(device)

    for _ in range(20):
        chunk_fwd_o(
            q=q,
            k=k,
            v=v,
            h=h,
            g=g,
            scale=scale,
            cu_seqlens=cu_seqlens,
            chunk_size=chunk_size
        )

    torch.npu.synchronize() if device == "npu" else None
    start_time = time.time()
    
    for _ in range(20):
        chunk_fwd_o(
            q=q,
            k=k,
            v=v,
            h=h,
            g=g,
            scale=scale,
            cu_seqlens=cu_seqlens,
            chunk_size=chunk_size
        )
  
    torch.npu.synchronize() if device == "npu" else None
    elapsed = (time.time() - start_time) / 20
    print(f"Task Duration: {elapsed*1000:.2f}ms")
